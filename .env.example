# Runtime
HOST=0.0.0.0
PORT=3000
PUBLIC_BASE_URL=http://localhost:3000
BODY_LIMIT_BYTES=12582912
DATA_DIR=data
DEFAULT_CURRENCY=CNY
DEFAULT_ACCOUNT_BALANCE=0
# 账户余额以“分”为单位存储，前端显示为“元”
NODE_ENV=production

# Auth / session
AUTH_SESSION_COOKIE_NAME=ivp_session
AUTH_SESSION_TTL_MS=604800000
AUTH_CODE_LENGTH=6
AUTH_CODE_TTL_MS=300000
AUTH_REGISTRATION_ENABLED=true
AUTH_PASSWORD_MIN_LENGTH=8
AUTH_EMAIL_REQUEST_LIMIT_WINDOW_MS=900000
AUTH_EMAIL_REQUEST_LIMIT_PER_EMAIL=5
AUTH_EMAIL_REQUEST_LIMIT_PER_IP=10
AUTH_EMAIL_DELIVERY_MODE=disabled
AUTH_EXPOSE_DEV_CODE=false
AUTH_EMAIL_SMTP_HOST=
AUTH_EMAIL_SMTP_PORT=587
AUTH_EMAIL_SMTP_SECURE=false
AUTH_EMAIL_SMTP_USERNAME=
AUTH_EMAIL_SMTP_PASSWORD=
AUTH_EMAIL_SMTP_FROM_EMAIL=
AUTH_EMAIL_SMTP_FROM_NAME=Astral Forge
AUTH_EMAIL_SMTP_REPLY_TO=
SUPER_ADMIN_EMAIL=
SUPER_ADMIN_ROLE=super_admin
SUPER_ADMIN_PASSWORD=
SMOKE_AUTH_EMAIL=
SMOKE_AUTH_SUBJECT_TYPE=user
SMOKE_OPERATOR_EMAIL=smoke-operator@example.com
SMOKE_SUPER_ADMIN_EMAIL=smoke-admin@example.com

# OpenAI-compatible image generation
OPENAI_IMAGE_BASE_URL=https://api.openai.com/v1
OPENAI_IMAGE_API_KEY=
OPENAI_IMAGE_MODEL=gpt-image-2
OPENAI_IMAGE_MODELS=gpt-image-2,gemini-3-pro-image-preview,gemini-3.1-flash-image
OPENAI_IMAGE_PATH=/images/generations
OPENAI_IMAGE_EDITS_PATH=/images/edits
OPENAI_RESPONSES_PATH=/responses
OPENAI_RESPONSES_MODEL=gpt-5.5
OPENAI_TIMEOUT_MS=120000

# Legacy compatibility also supported:
# base_url=
# api_key=
# model_name=

# SeedDance / Volcengine video generation
SEEDDANCE_BASE_URL=https://ark.cn-beijing.volces.com
SEEDDANCE_API_KEY=
SEEDDANCE_CREATE_PATH=/api/v3/contents/generations/tasks
SEEDDANCE_QUERY_PATH_TEMPLATE=/api/v3/contents/generations/tasks/{taskId}
SEEDDANCE_MODEL=doubao-seedance-2-0-250428
SEEDDANCE_DEFAULT_RESOLUTION=720p
SEEDDANCE_DEFAULT_RATIO=16:9
SEEDDANCE_DEFAULT_DURATION=5
SEEDDANCE_DEFAULT_GENERATE_AUDIO=true
SEEDDANCE_TIMEOUT_MS=180000
# 计费规则固定为：图片 ¥0.15 / 张，视频 ¥1.50 / 秒
# 线上请填可被支付回调和视频回调访问到的公网域名
# 例如 https://your-domain.example
# 本地 smoke 若要跑邮箱验证码链路，建议将 AUTH_EMAIL_DELIVERY_MODE=log、
# AUTH_EXPOSE_DEV_CODE=true，并设置 SUPER_ADMIN_EMAIL 或上面的 SMOKE_* 账号。
# 生产若要真实发信，请改成 AUTH_EMAIL_DELIVERY_MODE=smtp 并补全上面的 SMTP 配置。

# Junliai aggregated payments
JUNLIAI_PAY_GATEWAY=https://pay.junliai.com
JUNLIAI_PAY_PID=
JUNLIAI_PAY_PRIVATE_KEY=
JUNLIAI_PAY_PLATFORM_PUBLIC_KEY=
JUNLIAI_PAY_NOTIFY_URL=
JUNLIAI_PAY_RETURN_URL=
JUNLIAI_PAY_CREATE_PATH=/api/pay/create
JUNLIAI_PAY_QUERY_PATH=/api/pay/query
JUNLIAI_PAY_SUBMIT_PATH=/api/pay/submit
JUNLIAI_PAY_METHOD=web
JUNLIAI_PAY_DEVICE=pc
# 若不填，后端会回退到 ${PUBLIC_BASE_URL}/api/payments/junliai/notify
